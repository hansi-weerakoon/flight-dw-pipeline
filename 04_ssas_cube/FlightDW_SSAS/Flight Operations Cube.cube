  <Kpis>
    <Kpi dwd:design-time-name="deaa3804-b2e2-4275-b304-4e8566c77792">
      <ID>KPI</ID>
      <Name>On-Time Performance Rate</Name>
      <Value>[Measures].[Flight Count] - [Measures].[Cancelled Flights]</Value>
      <Goal>[Measures].[Flight Count]</Goal>
      <Status>IIF([KPIs].[On-Time Performance Rate].[Goal] = 0, null,
    [KPIs].[On-Time Performance Rate].[Value] /
    [KPIs].[On-Time Performance Rate].[Goal])</Status>
      <Trend>([Measures].[Flight Count] - [Measures].[Cancelled Flights])
    - (ParallelPeriod([Dim Date].[Calendar].[Year], 1, 
       [Measures].[Flight Count] - [Measures].[Cancelled Flights]))</Trend>
      <TrendGraphic>Standard Arrow</TrendGraphic>
      <StatusGraphic>Gauge - Ascending</StatusGraphic>
    </Kpi>
  </Kpis>
</Cube>