    <DTS:Executable
      DTS:refId="Package\Load Dim_Date — SQL script task"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{93CC3BFF-BDE6-40EF-987F-083D72F9E393}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Dim_Date — SQL script task"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{38AFA3F4-F058-4AF1-AF63-F5FDC6B94540}"
          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT 1 FROM dbo.Dim_Date WHERE date_key = 20240101)&#xA;&#xA;BEGIN&#xA;    &#xA;&#x9;DECLARE @d DATE = '2024-01-01';&#xA;    &#xA;&#x9;DECLARE @end DATE = '2024-12-31';&#xA;&#xA;    &#xA;&#x9;WHILE @d &lt;= @end&#xA;    &#xA;&#x9;BEGIN&#xA;       &#xA;&#x9;&#x9;INSERT INTO dbo.Dim_Date (&#xA;            &#xA;&#x9;&#x9;&#x9;date_key, full_date, year, quarter, quarter_name,&#xA; month, month_name, month_year, week_of_year,&#xA; day_of_month, day_of_week, day_name, is_weekend, is_public_holiday&#xA;        )&#xA;&#xA;&#x9;&#x9; VALUES (&#xA;            &#xA;&#x9;&#x9;&#x9;CAST(FORMAT(@d, 'yyyyMMdd') AS INT),&#xA;            &#xA;&#x9;&#x9;&#x9;@d,&#xA;            &#xA;&#x9;&#x9;&#x9;YEAR(@d),&#xA;            &#xA;&#x9;&#x9;&#x9;DATEPART(QUARTER, @d),&#xA;           &#xA;&#x9;&#x9;&#x9; 'Q' + CAST(DATEPART(QUARTER, @d) AS VARCHAR(1)),&#xA;            &#xA;&#x9;&#x9;&#x9;MONTH(@d),&#xA;            &#xA;&#x9;&#x9;&#x9;DATENAME(MONTH, @d),&#xA;           &#xA;&#x9;&#x9;&#x9;LEFT(DATENAME(MONTH, @d), 3) + ' ' + CAST(YEAR(@d) AS VARCHAR(4)),&#xA;            &#xA;&#x9;&#x9;&#x9;DATEPART(ISO_WEEK, @d),&#xA;            &#xA;&#x9;&#x9;&#x9;DAY(@d),&#xA;            &#xA;&#x9;&#x9;&#x9;DATEPART(WEEKDAY, @d),&#xA;            &#xA;&#x9;&#x9;&#x9;DATENAME(WEEKDAY, @d),&#xA;            &#xA;&#x9;&#x9;&#x9;CASE WHEN DATEPART(WEEKDAY, @d) IN (1, 7) THEN 1 ELSE 0 END,&#xA;            &#xA;&#x9;&#x9;&#x9;0&#xA;        );&#xA;        &#xA;&#x9;&#x9;SET @d = DATEADD(DAY, 1, @d);&#xA;    &#xA;&#x9;END;&#xA;&#xA;      &#xA;&#x9;UPDATE dbo.Dim_Date SET is_public_holiday = 1&#xA;    &#xA;&#x9;WHERE date_key IN (&#xA;20240101, 20240115, 20240219, 20240527, 20240619,&#xA; 20240704, 20240902, 20241014, 20241111, 20241128, 20241225&#xA; );&#xA;&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
