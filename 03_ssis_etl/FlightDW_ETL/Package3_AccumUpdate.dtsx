    <DTS:Executable
      DTS:refId="Package\SQL_Validate_AccumStaging"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{8514307D-0E35-419F-A539-5C643AE05859}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Validate_AccumStaging"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{5EFE406E-4576-4384-976D-564AF18E518D}"
          SQLTask:SqlStatementSource="DECLARE @staged   INT = (SELECT COUNT(*) FROM FlightDW_Staging.dbo.stg_AccumCompletion);&#xA;DECLARE @distinct INT = (SELECT COUNT(DISTINCT operation_id) FROM   FlightDW_Staging.dbo.stg_AccumCompletion);&#xA;&#xA;PRINT 'Rows staged:              ' + CAST(@staged   AS VARCHAR);&#xA;PRINT 'Distinct operation_ids:   ' + CAST(@distinct AS VARCHAR);&#xA;PRINT 'Duplicate operation_ids:  ' + CAST(@staged - @distinct AS VARCHAR);&#xA;&#xA;-- If duplicates exist, keep only the latest completion time per operation_id&#xA;-- (a flight can only complete once — take the most recent if file has dups)&#xA;IF @staged &gt; @distinct&#xA;BEGIN&#xA;    PRINT 'Deduplicating — keeping latest completion time per operation_id...';&#xA;    WITH ranked AS (&#xA;        SELECT *,&#xA;               ROW_NUMBER() OVER (&#xA;                   PARTITION BY operation_id&#xA;                   ORDER BY accm_txn_complete_time DESC&#xA;               ) AS rn&#xA;        FROM FlightDW_Staging.dbo.stg_AccumCompletion&#xA;    )&#xA;    DELETE FROM FlightDW_Staging.dbo.stg_AccumCompletion&#xA;    WHERE  operation_id IN (&#xA;        SELECT operation_id FROM ranked WHERE rn &gt; 1&#xA;    );&#xA;    PRINT 'Deduplication complete.';&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
